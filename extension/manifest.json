{
  "manifest_version": 3,
  "name": "HirePath Autofill",
  "version": "1.0.0",
  "description": "Auto-fill job application forms with your HirePath profile. Works on Greenhouse, Lever, Ashby, LinkedIn, Indeed, Workday and more.",
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "host_permissions": [
    "*://*/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "HirePath Autofill"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
