# ── Supabase (required for multi-user / production) ──────────────────────────
# Get these from: Supabase Dashboard → Project → Settings → API
# Leave blank to use local SQLite (single-user dev mode)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Get from: Supabase Dashboard → Project → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
MAGIC_API_KEY=

# --- Telegram ---
# Create a bot via @BotFather, then DM your bot once and check
# https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Paths ---
DATA_DIR=./data
RESUME_PATH=./data/resume_master.md       # markdown master resume
RESUME_DOCX_PATH=./data/resume_master.docx # for python-docx editing
FAISS_INDEX_PATH=./data/jobs.faiss
SQLITE_PATH=./data/jobagent.db

# --- Personal data for autofill ---
# Anything sensitive is asked via Telegram at runtime, NOT stored here.
APPLICANT_FIRST_NAME=Karthik
APPLICANT_LAST_NAME=
APPLICANT_EMAIL=
APPLICANT_PHONE=
APPLICANT_LOCATION=Cincinnati, OH
APPLICANT_GITHUB=https://github.com/karthiklucky1
APPLICANT_LINKEDIN=
APPLICANT_WORK_AUTH=US Citizen  # or H1B, OPT, etc — adjust to your situation

# --- Matching (defaults mirror app/config.py) ---
MIN_MATCH_SCORE=0.15    # cross-encoder score threshold for rerank candidates
TOP_K_RERANK=600        # retrieval candidates considered (LLM rerank is capped separately)
DAILY_APPLY_LIMIT=25    # per-user cap on auto-submissions per day
DISCOVERY_INTERVAL_HOURS=6  # scheduler cadence for automatic discovery+matching

# --- Direct-ATS sourcing (live jobs, direct apply links) ---
DIRECT_ATS_ENABLED=true       # scrape active CompanyRegistry boards every run
MAX_BOARDS_PER_RUN=300        # boards scraped per run (rotates least-recent first)
VERIFY_LINKS_ON_SHORTLIST=true  # HEAD-check non-ATS links before shortlisting

# --- Keyed job sources (auto-activate when the key is set; *_ENABLED=false forces off) ---
# SerpAPI — Google Jobs (LinkedIn/Indeed/Glassdoor, direct apply links, 7-day fresh).
# The single biggest quality lever. Sign up: https://serpapi.com (free: 100 searches/mo)
SERPAPI_KEY=
# Adzuna — country-aware board. Keys: https://developer.adzuna.com (free)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Reed.co.uk — UK jobs. Key: https://www.reed.co.uk/developers (free)
REED_API_KEY=
# Jooble — global aggregator. Key: https://jooble.org/api/about (free)
JOOBLE_API_KEY=
# LinkedIn via RapidAPI (~$10/mo): https://rapidapi.com (search "linkedin jobs search")
RAPIDAPI_KEY=

# --- Discovery target companies (Greenhouse/Lever/Ashby boards) ---
# Comma-separated board slugs. Add the AI/ML companies you actually care about.
GREENHOUSE_BOARDS=anthropic,openai,scaleai,databricks,huggingface
LEVER_BOARDS=ramp,mistral
ASHBY_BOARDS=anthropic

# ── Payments (leave empty until the LLC + Stripe account exist) ──────────────
# With all three unset, payments are OFF and every user gets Pro free.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID_PRO=
STRIPE_WEBHOOK_SECRET=
# Manual payment path shown on the upgrade screen until Stripe is live:
PAYMENT_BANK_DETAILS=
PAYMENT_CONTACT_EMAIL=karthiklucky899@gmail.com
# Score with free local models when no LLM provider is usable (default on)
LOCAL_SCORE_FALLBACK=1

# ── Memory footprint (Railway OOM tuning) ────────────────────────────────────
# The container holds torch + the MiniLM embedder permanently; the distilled
# scorer and the local cross-encoder load lazily but stay resident once used.
# If Railway shows "Out of memory" restarts, apply in this order:
#   1. Raise the service memory limit (Settings → Resources) to 2GB+.
#   2. LOCAL_SCORER_SHADOW=0 — stop re-scoring every LLM final with the local
#      model (saves ~200-400MB once tripped + a 2nd inference per job). The
#      local model still loads on demand if LLM providers go down.
#   3. MAX_BOARDS_PER_RUN=250 — smaller discovery batches (default 400; 800
#      contributed to a past OOM).
#   4. SCORING_WORKERS=10 / PRESCORE_WORKERS=8 — fewer concurrent LLM calls
#      buffering request/response payloads.
# LOCAL_SCORER_SHADOW=0
# MAX_BOARDS_PER_RUN=250
# SCORING_WORKERS=10
# PRESCORE_WORKERS=8
